{
  "name": "hive",
  "version": "0.1.0",
  "tasks": {
    "dev": "deno run --allow-env --allow-read --allow-write --allow-run --allow-net cli.ts",
    "test": "deno test --allow-env --allow-read --allow-write --allow-run",
    "fmt": "deno fmt",
    "lint": "deno lint",
    "compile": "deno compile --allow-env --allow-read --allow-write --allow-run --allow-net --output=hive cli.ts"
  },
  "imports": {
    "@clack/prompts": "npm:@clack/prompts@^0.11"
  },
  "fmt": {
    "lineWidth": 100,
    "semiColons": true
  },
  "lint": {
    "rules": {
      "exclude": ["no-explicit-any"]
    }
  }
}
